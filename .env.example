# Server Configuration
NODE_ENV=development
PORT=3000
HOST=localhost

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=hr_management_db
DB_DIALECT=mysql

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_token_secret

# Biometric Device Configuration
BIOMETRIC_DEVICE_PORT=/dev/ttyUSB0
BIOMETRIC_DEVICE_BAUDRATE=115200
BIOMETRIC_TIMEOUT=5000
BIOMETRIC_MAX_RETRIES=3

# GPS Configuration
GPS_ACCURACY_THRESHOLD=50
GPS_CHECK_INTERVAL=300000
GPS_ENABLE_LIVE_TRACKING=true
GPS_OFFICE_LATITUDE=30.0444
GPS_OFFICE_LONGITUDE=31.2357
GPS_OFFICE_RADIUS=500

# File Upload Configuration
MAX_FILE_SIZE=5242880
ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf
UPLOAD_PATH=./public/uploads

# Email Configuration (Optional)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@hrmanagement.com

# Logging Configuration
LOG_LEVEL=debug
LOG_FILE_PATH=./logs

# Security
BCRYPT_ROUNDS=10
SESSION_SECRET=your-session-secret-key
CORs_ORIGIN=http://localhost:3000

# Payment/Payroll Configuration
CURRENCY=EGP
PAYROLL_FREQUENCY=monthly

# Report Generation
REPORT_EXPORT_FORMAT=pdf,excel
